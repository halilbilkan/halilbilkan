            --neon-blue: #0077b6;
            --neon-orange: #e67e22;
        }

        body {
            font-family: 'Inter', 'Segoe UI', sans-serif;
            background-color: var(--bg-color);
            color: var(--text-main);
            margin: 0;
            transition: background-color 0.4s, color 0.4s;
        }

        /* Theme Toggle */
        .theme-btn {
