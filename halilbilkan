        }

        h1 {
            font-size: 3rem; letter-spacing: 4px;
            text-shadow: 0 0 10px var(--neon-blue), 0 0 30px var(--neon-blue);
        }

        .container { max-width: 900px; margin: 0 auto; padding: 40px 20px; }

